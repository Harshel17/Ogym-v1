# OGym Local Development Environment Variables
# Copy this file to .env and fill in your values

# PostgreSQL Database Connection (REQUIRED)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/ogym

# Session Secret for Express (REQUIRED)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your-secure-session-secret-here

# Individual PostgreSQL connection variables (used by some tools)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=yourpassword
PGDATABASE=ogym
