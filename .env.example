# OGym Environment Variables
# Copy this file to .env and fill in your values

# Database (Required)
DATABASE_URL=

# Session secret - 32+ characters (Required in production)
SESSION_SECRET=

# Admin credentials (Recommended)
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Email service (Optional - falls back to console logging)
RESEND_API_KEY=
FROM_EMAIL=

# Server configuration
PORT=
NODE_ENV=

# Development only - skip email verification
DISABLE_EMAIL_VERIFICATION=

# Frontend API base (if needed)
VITE_API_BASE_URL=
