# OGym Backend Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# PRODUCTION (Render) Configuration
# ============================================

# PostgreSQL Database Connection (REQUIRED)
# Render provides this automatically when you add a PostgreSQL database
DATABASE_URL=postgresql://user:password@host:5432/database

# Session Secret for Express (REQUIRED)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your-secure-session-secret-here

# Admin credentials for platform admin user (REQUIRED)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-admin-password

# Server port (Render sets this automatically, default 5000)
PORT=5000

# Node environment
NODE_ENV=production

# ============================================
# LOCAL DEVELOPMENT Configuration
# ============================================

# Individual PostgreSQL connection variables (used by some tools)
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=yourpassword
# PGDATABASE=ogym
