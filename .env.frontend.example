# OGym Frontend Environment Variables (for Vercel deployment)
# Add these to your Vercel project settings under Environment Variables

# API URL pointing to your Render backend (REQUIRED)
# Replace with your actual Render service URL
VITE_API_URL=https://your-backend.onrender.com

# Note: For local development, the Vite dev server proxies API calls
# so VITE_API_URL is not needed locally
